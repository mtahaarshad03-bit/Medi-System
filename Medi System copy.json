        "subject": "=🩺 New Appointment Booked",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n</head>\n\n<body style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:40px 0;\">\n\n<tr>\n<td align=\"center\">\n\n<table width=\"650\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 5px 18px rgba(0,0,0,.08);\">\n\n<tr>\n<td style=\"background:#0F62FE;color:white;padding:25px;text-align:center;font-size:28px;font-weight:bold;\">\n📅 New Appointment Booked\n</td>\n</tr>\n\n<tr>\n<td style=\"padding:35px;\">\n\n<h2 style=\"margin-top:0;color:#333;\">\nA new patient appointment has been booked.\n</h2>\n\n<table width=\"100%\" cellpadding=\"12\" cellspacing=\"0\" style=\"border-collapse:collapse;margin-top:25px;\">\n\n<tr style=\"background:#f8f9fc;\">\n<td><strong>Patient Name</strong></td>\n<td>{{ $json.body.patientName }}</td>\n</tr>\n\n<tr>\n<td><strong>Phone Number</strong></td>\n<td>{{ $json.body.phoneNumber }}</td>\n</tr>\n\n<tr style=\"background:#f8f9fc;\">\n<td><strong>Email</strong></td>\n<td>{{ $json.body.email }}</td>\n</tr>\n\n<tr>\n<td><strong>Doctor</strong></td>\n<td>{{ $json.body.doctor }}</td>\n</tr>\n\n<tr style=\"background:#f8f9fc;\">\n<td><strong>Specialization</strong></td>\n<td>{{ $json.body.specialization }}</td>\n</tr>\n\n<tr>\n<td><strong>Appointment Date</strong></td>\n<td>{{ $json.body.appointmentDate }}</td>\n</tr>\n\n<tr style=\"background:#f8f9fc;\">\n<td><strong>Appointment Time</strong></td>\n<td>{{ $json.body.appointmentTime }}</td>\n</tr>\n\n</table>\n\n<p style=\"margin-top:30px;color:#666;font-size:15px;\">\nPlease review this appointment and prepare accordingly.\n</p>\n\n</td>\n</tr>\n\n<tr>\n<td style=\"background:#f2f5fa;padding:18px;text-align:center;color:#777;font-size:13px;\">\nMedical Appointment System\n</td>\n</tr>\n\n</table>\n\n</td>\n</tr>\n\n</table>\n\n</body>\n</html>",
