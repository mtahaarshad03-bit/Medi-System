    {
      "parameters": {
        "sendTo": "={{ $json.body.email }}",
        "subject": "=Thank You for Booking Your Appointment",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n</head>\n\n<body style=\"margin:0;padding:0;background:#eef3f9;font-family:Arial,Helvetica,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:40px 0;\">\n\n<tr>\n<td align=\"center\">\n\n<table width=\"650\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:14px;overflow:hidden;box-shadow:0 5px 18px rgba(0,0,0,.08);\">\n\n<tr>\n<td style=\"background:#16A34A;padding:35px;text-align:center;color:white;\">\n\n<div style=\"font-size:55px;\">✅</div>\n\n<h1 style=\"margin:10px 0 0;\">\nAppointment Confirmed\n</h1>\n\n</td>\n</tr>\n\n<tr>\n<td style=\"padding:40px;\">\n\n<h2 style=\"color:#222;\">\nDear {{ $json.body.patientName }},\n</h2>\n\n<p style=\"font-size:16px;color:#555;line-height:28px;\">\n\nThank you for choosing our medical services.\n\nYour appointment has been successfully confirmed.\n\nBelow are your appointment details.\n\n</p>\n\n<table width=\"100%\" cellpadding=\"14\" cellspacing=\"0\" style=\"border-collapse:collapse;margin-top:30px;border:1px solid #e5e7eb;\">\n\n<tr style=\"background:#f8fafc;\">\n<td width=\"35%\"><strong>Doctor</strong></td>\n<td>{{ $json.body.doctor }}</td>\n</tr>\n\n<tr>\n<td><strong>Specialization</strong></td>\n<td>{{ $json.body.specialization }}</td>\n</tr>\n\n<tr style=\"background:#f8fafc;\">\n<td><strong>Date</strong></td>\n<td>{{ $json.body.appointmentDate }}</td>\n</tr>\n\n<tr>\n<td><strong>Time</strong></td>\n<td>{{ $json.body.appointmentTime }}</td>\n</tr>\n\n</table>\n\n<p style=\"margin-top:35px;color:#555;font-size:16px;line-height:28px;\">\n\nPlease arrive at least <strong>15 minutes before</strong> your scheduled appointment.\n\nIf you need to cancel or reschedule, kindly contact us in advance.\n\n</p>\n\n<div style=\"margin-top:35px;text-align:center;\">\n\n<a href=\"#\" style=\"background:#16A34A;color:white;padding:15px 35px;text-decoration:none;border-radius:8px;font-weight:bold;display:inline-block;\">\nView Appointment\n</a>\n\n</div>\n\n<p style=\"margin-top:40px;font-size:16px;color:#444;\">\n\nWe look forward to seeing you.\n\nThank you for trusting our healthcare services.\n\n</p>\n\n<p style=\"margin-top:30px;\">\n\nBest Regards,<br>\n\n<strong>Medical Appointment Team</strong>\n\n</p>\n\n</td>\n</tr>\n\n<tr>\n<td style=\"background:#f3f4f6;padding:18px;text-align:center;color:#777;font-size:13px;\">\n\n© 2026 Medical Appointment System\n\n</td>\n</tr>\n\n</table>\n\n</td>\n</tr>\n\n</table>\n\n</body>\n</html>",
        "options": {}
      },
